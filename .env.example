# Zyra Net API — Environment Variables
# Copy this to .env and fill in real values for production.

# --- App ---
APP_ENV=local
APP_PORT=8080

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zyranet
DB_USER=root
DB_PASS=your_db_password_here

# --- JWT ---
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRY=24h

# --- Auth cookie ---
# Leave blank for local dev (host-only cookie). In production set to
# .zyranet.co.ke so the session cookie set by the API is also sent to
# admin.zyranet.co.ke and portal.zyranet.co.ke.
COOKIE_DOMAIN=

# --- M-Pesa (Safaricom Daraja) ---
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.zyranet.co.ke/api/v1/mpesa/callback

# --- SMS Gateway Provider ---
# Options: africastalking, hostpinnacle
SMS_PROVIDER=hostpinnacle

# --- Hostpinnacle SMS ---
HOSTPINNACLE_BASE_URL=https://smsportal.hostpinnacle.co.ke/SMSApi/send
HOSTPINNACLE_API_KEY=
HOSTPINNACLE_USERNAME=
HOSTPINNACLE_PASSWORD=
HOSTPINNACLE_SENDER_ID=

# --- Africa's Talking SMS ---
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=ZyraNet

# --- Error monitoring (Sentry) ---
# Leave blank to disable error reporting entirely (e.g. local dev).
SENTRY_DSN=
